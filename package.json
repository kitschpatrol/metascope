{
	"name": "metascope",
	"version": "0.0.0",
	"description": "Easily extract all kinds of metadata from a code repository.",
	"keywords": [
		"cli",
		"metadata",
		"codemeta",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/metascope",
	"bugs": "https://github.com/kitschpatrol/metascope/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/metascope.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/lib/index.d.ts",
			"import": "./dist/lib/index.js"
		}
	},
	"main": "./dist/lib/index.js",
	"module": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"bin": {
		"metascope": "dist/bin/cli.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"pretest": "cp node_modules/tree-sitter-ruby/tree-sitter-ruby.wasm src/lib/grammars/tree-sitter-ruby.wasm && cp node_modules/tree-sitter-python/tree-sitter-python.wasm src/lib/grammars/tree-sitter-python.wasm",
		"test": "vitest"
	},
	"dependencies": {
		"@bacons/xcode": "1.0.0-alpha.33",
		"@kitschpatrol/codemeta": "link:../codemeta",
		"@kitschpatrol/tokei": "^2.0.0",
		"@sindresorhus/is": "^7.2.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "~24.1.0",
		"@types/plist": "^3.0.5",
		"@types/yargs": "^17.0.35",
		"case-police": "^2.2.0",
		"fast-xml-parser": "^5.4.2",
		"git-url-parse": "^16.1.0",
		"jiti": "^2.6.1",
		"lognow": "^0.5.2",
		"octokit": "^5.0.5",
		"package-json": "^10.0.1",
		"pkg-types": "^2.3.0",
		"plist": "^3.1.0",
		"read-pkg": "^10.1.0",
		"read-pyproject": "^0.3.0",
		"remark-parse": "^11.0.0",
		"scule": "^1.3.0",
		"semver": "^7.7.4",
		"simple-git": "^3.32.3",
		"smol-toml": "^1.6.0",
		"spdx-license-list": "^6.11.0",
		"tinyexec": "^1.0.2",
		"tinyglobby": "^0.2.15",
		"tree-sitter-python": "^0.25.0",
		"tree-sitter-ruby": "^0.23.1",
		"unified": "^11.0.5",
		"updates": "^17.8.3",
		"web-tree-sitter": "^0.26.6",
		"yaml": "^2.8.2",
		"yargs": "^18.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@fast-csv/parse": "^5.0.5",
		"@kitschpatrol/shared-config": "^6.0.2",
		"@types/semver": "^7.7.1",
		"bumpp": "^10.4.1",
		"mdat-plugin-cli-help": "^1.0.7",
		"publint": "^0.3.18",
		"tsdown": "^0.21.0",
		"typescript": "~5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.31.0",
	"engines": {
		"node": ">=24.1.0"
	}
}
