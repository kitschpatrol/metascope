{
	"name": "arbitrum-flash",
	"version": "1.0.0",
	"description": "Experimental Arbitrage Bot targeting Uniswap V3 on Arbitrum One using flash loans. Includes an on-chain executor contract (Hardhat) and an off-chain monitor (Node.js). Private development. HIGH RISK.",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"compile": "hardhat compile",
		"test": "NETWORK=localfork hardhat test",
		"test:anvil": "forge test --fork-url ${ARBITRUM_RPC_URL} --fork-block-number 228000000 -vvv",
		"test:suite": "NETWORK=localfork hardhat test",
		"diagnose:flashswap-call-exception": "./node_modules/.bin/hardhat run scripts/debug/diagnose-flashswap-call-exception.js --network hardhat",
		"lint": "eslint \"**/*.{js,ts}\"",
		"clean": "rm -rf dist",
		"build": "rm -rf dist && tsc -p tsconfig.build.json && cp -r abis dist/",
		"start": "yarn build && node dist/bot.js",
		"anvil:fork": "anvil --fork-url https://arb-mainnet.g.alchemy.com/v2/$ALCHEMY_API_KEY",
		"audit:slither": "slither . --fail-medium",
		"verify:arbitrum": "dotenv -e ./.env -- hardhat verify --network arbitrum"
	},
	"engines": {
		"npm": "prohibited",
		"yarn": ">=1.22.0"
	},
	"jest": {
		"moduleNameMapper": {
			"^@config/(.*)$": "<rootDir>/src/configs/$1",
			"^@src/(.*)$": "<rootDir>/src/$1",
			"^@utils/(.*)$": "<rootDir>/src/utils/$1",
			"^@infra/(.*)$": "<rootDir>/src/infra/$1",
			"^@core/(.*)$": "<rootDir>/src/core/$1",
			"^@services/(.*)$": "<rootDir>/src/services/$1",
			"^@protocols/(.*)$": "<rootDir>/src/protocols/$1",
			"^@lib/(.*)$": "<rootDir>/src/lib/$1",
			"^@abisRoot/(.*)$": "<rootDir>/abis/$1",
			"^@artifactsRoot/(.*)$": "<rootDir>/artifacts/$1"
		},
		"transform": {
			"^.+\\.tsx?$": "ts-jest"
		}
	},
	"_moduleAliases": {
		"@config": "dist/configs",
		"@core": "dist/core",
		"@data": "dist/data",
		"@infra": "dist/infra",
		"@protocols": "dist/protocols",
		"@services": "dist/services",
		"@tools": "dist/tools",
		"@utils": "dist/utils",
		"@src": "dist",
		"@lib": "dist/lib",
		"@abisRoot": "dist/abis",
		"@artifactsRoot": "dist/artifacts"
	},
	"keywords": [],
